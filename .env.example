# Supabase (DB only — no auth needed for users)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# AWS SES (email delivery — $0.10/1K emails)
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
AWS_SES_REGION=ap-south-1
SES_FROM_EMAIL=digest@yourdomain.com

# Upstash QStash (batched email fan-out)
QSTASH_TOKEN=your-qstash-token

# Groq (LLM for summaries)
GROQ_API_KEY=gsk_your-groq-api-key

# Football Data (football-data.org — free tier)
FOOTBALL_DATA_TOKEN=your-football-data-token

# YouTube Data API v3 (highlight video search — 10K units/day free)
YOUTUBE_API_KEY=your-youtube-api-key

# Cron job secret (protect internal endpoints)
CRON_SECRET=your-random-secret-here

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
